#!/usr/bin/env fish
# vibe-kanban — Launch vibe-kanban dev server with remote API configuration
#
# Clones or updates the vibe-kanban repository, installs dependencies,
# and launches either the production build or development server.
# Configures remote API base URL and MCP server connection settings.
#
# Dependencies: git, pnpm, cargo, node
# Usage: vibe-kanban [--help|-h]

# ── Colors ───────────────────────────────────────────────────────────────────
set -l GREEN  '\033[0;32m'
set -l YELLOW '\033[1;33m'
set -l RED    '\033[0;31m'
set -l BLUE   '\033[0;34m'
set -l NC     '\033[0m'

function log_info
    echo -e "$GREEN[INFO]$NC $argv"
end

function log_warn
    echo -e "$YELLOW[WARN]$NC $argv"
end

function log_error
    echo -e "$RED[ERROR]$NC $argv" >&2
end

function log_step
    echo -e "$BLUE[STEP]$NC $argv"
end

# ── Help ─────────────────────────────────────────────────────────────────────
if contains -- --help $argv; or contains -- -h $argv
    echo "Usage: vibe-kanban [--help|-h]"
    echo ""
    echo "Launches vibe-kanban configured for vibe-kanban.fractal-tess.xyz."
    echo "Clones the repo on first run, pulls updates on subsequent runs."
    echo "Runs the production build if available, otherwise dev mode."
    echo ""
    echo "Environment overrides (optional):"
    echo "  VK_SHARED_API_BASE      Remote API base URL"
    echo "  VITE_VK_SHARED_API_BASE Vite-visible API base URL"
    echo "  VK_ALLOWED_ORIGINS      CORS allowed origins (comma-separated)"
    echo "  BACKEND_PORT            Backend port (default: 31112)"
    echo "  FRONTEND_PORT           Frontend dev port (default: 31111)"
    echo "  HOST                    Bind host (default: 0.0.0.0)"
    echo "  MCP_HOST                MCP server host (default: 127.0.0.1)"
    echo "  MCP_PORT                MCP server port (default: BACKEND_PORT)"
    echo "  RUST_LOG                Rust log level (default: info)"
    echo "  VIBE_KANBAN_REPO        Repo directory (default: ~/dev/vibe-kanban)"
    echo ""
    echo "Dependencies: git, pnpm, cargo, node"
    exit 0
end

# ── Environment configuration ─────────────────────────────────────────────────

# Remote API Base URL
if not set -q VK_SHARED_API_BASE
    set -x VK_SHARED_API_BASE "https://vibe-kanban.fractal-tess.xyz"
end
if not set -q VITE_VK_SHARED_API_BASE
    set -x VITE_VK_SHARED_API_BASE $VK_SHARED_API_BASE
end

# Allowed Origins for CORS
if not set -q VK_ALLOWED_ORIGINS
    set -x VK_ALLOWED_ORIGINS ""
end

# Port configuration
if not set -q BACKEND_PORT
    set -x BACKEND_PORT "31112"
end
if not set -q FRONTEND_PORT
    set -x FRONTEND_PORT "31111"
end

# Backend server host
if not set -q HOST
    set -x HOST "0.0.0.0"
end

# MCP server connection configuration
if not set -q MCP_HOST
    set -x MCP_HOST "127.0.0.1"
end
if not set -q MCP_PORT
    set -x MCP_PORT $BACKEND_PORT
end

# Logging level
if not set -q RUST_LOG
    set -x RUST_LOG "info"
end

# ── Dependency checks ─────────────────────────────────────────────────────────
log_step "Checking dependencies..."

set -l deps_ok true

if not type -q git
    log_error "git not found! Please install git."
    set deps_ok false
end

if not type -q pnpm
    log_error "pnpm not found! Please install pnpm: npm install -g pnpm"
    set deps_ok false
end

if not type -q cargo
    log_warn "cargo not found in PATH, but may be available in dev environment"
end

if test "$deps_ok" = false
    log_error "Missing required dependencies. Please install them and try again."
    exit 1
end

log_info "All dependencies found!"

# ── Repository setup ─────────────────────────────────────────────────────────
if not set -q VIBE_KANBAN_REPO
    set -x VIBE_KANBAN_REPO "$HOME/dev/vibe-kanban"
end

set -l REPO_URL "https://github.com/Fractal-Tess/vibe-kanban.git"

mkdir -p /tmp

if not test -d "$VIBE_KANBAN_REPO"
    log_step "Cloning vibe-kanban repository to $VIBE_KANBAN_REPO..."

    if not git clone "$REPO_URL" "$VIBE_KANBAN_REPO"
        log_error "Failed to clone repository"
        exit 1
    end

    log_info "Repository cloned successfully!"
else
    log_step "Updating vibe-kanban repository..."

    # Check if repo is clean
    set -l git_dirty (git -C "$VIBE_KANBAN_REPO" diff-index --quiet HEAD -- 2>/dev/null; echo $status)
    if test "$git_dirty" != "0"
        log_warn "Repository has uncommitted changes, skipping update"
    else
        if not git -C "$VIBE_KANBAN_REPO" pull --ff-only 2>/dev/null
            log_warn "Failed to update repository, using existing version"
        else
            log_info "Repository updated successfully!"
        end
    end
end

# ── Install dependencies ──────────────────────────────────────────────────────
log_step "Installing/updating dependencies..."

# pnpm install in repo root (suppress progress spam)
if not pnpm --dir "$VIBE_KANBAN_REPO" install --prefer-offline 2>&1 | grep -v "Progress:"
    log_error "Failed to install dependencies"
    exit 1
end

log_info "Dependencies ready!"

# ── Install npx-cli dependencies (if production build exists) ────────────────
if test -f "$VIBE_KANBAN_REPO/npx-cli/bin/cli.js"; and test -d "$VIBE_KANBAN_REPO/npx-cli/dist"
    log_step "Installing npx-cli dependencies..."

    if not pnpm --dir "$VIBE_KANBAN_REPO/npx-cli" install --ignore-workspace --prefer-offline 2>&1 | grep -v "Progress:"
        log_error "Failed to install npx-cli dependencies"
        exit 1
    end

    log_info "npx-cli dependencies ready!"
end

# ── Launch ────────────────────────────────────────────────────────────────────
log_info "Starting vibe-kanban..."
log_info "Repository:   $VIBE_KANBAN_REPO"
log_info "Backend Port: $BACKEND_PORT"
log_info "Frontend Port: $FRONTEND_PORT"
log_info "Host:         $HOST"
log_info "Remote API Base: $VK_SHARED_API_BASE"
if test -n "$VK_ALLOWED_ORIGINS"
    log_info "Allowed Origins: $VK_ALLOWED_ORIGINS"
else
    log_info "Allowed Origins: <not set>"
end
log_info "MCP Host: $MCP_HOST"
log_info "MCP Port: $MCP_PORT"

echo ""
log_step "Launching vibe-kanban..."

# Load direnv environment if .envrc exists
if test -f "$VIBE_KANBAN_REPO/.envrc"
    log_info "Loading direnv environment..."
    if type -q direnv
        eval (direnv export fish 2>/dev/null); or log_warn "Failed to load direnv, continuing anyway..."
    else
        log_warn "direnv not found, skipping .envrc"
    end
end

# Check if built version exists
if test -f "$VIBE_KANBAN_REPO/npx-cli/bin/cli.js"; and test -d "$VIBE_KANBAN_REPO/npx-cli/dist"
    log_info "Running production build..."
    cd "$VIBE_KANBAN_REPO/npx-cli"
    exec node bin/cli.js
else
    log_warn "Production build not found, running in development mode..."
    cd "$VIBE_KANBAN_REPO"
    exec pnpm run dev
end
