#!/usr/bin/env fish
# mount — SSHFS mount manager (currently configured for neo-blockade)
#
# Merged from neo-blockade-mount and neo-blockade-umount. Manages
# sshfs mounts with reconnect and keep-alive options.
#
# Dependencies: sshfs, sudo, fusermount3 (or fusermount/umount)
# Usage: mount [neo-blockade|umount neo-blockade|status] [--help|-h]

set REMOTE_HOST neo
set REMOTE_PATH /mnt/blockade
set LOCAL_MOUNT /mnt/blockade

function log_info
    printf '\033[0;32m[INFO]\033[0m  %s\n' "$argv"
end

function log_warn
    printf '\033[1;33m[WARN]\033[0m  %s\n' "$argv"
end

function log_error
    printf '\033[0;31m[ERROR]\033[0m %s\n' "$argv" >&2
end

function log_step
    printf '\033[0;34m[STEP]\033[0m  %s\n' "$argv"
end

function show_help
    echo "Usage: mount <subcommand>"
    echo ""
    echo "Subcommands:"
    echo "  neo-blockade        Mount neo:/mnt/blockade at /mnt/blockade via sshfs"
    echo "  umount neo-blockade Unmount /mnt/blockade"
    echo "  status              Show currently mounted sshfs mounts"
    echo ""
    echo "Options:"
    echo "  --help, -h  Show this help message"
    echo ""
    echo "sshfs options: reconnect, ServerAliveInterval=15, ServerAliveCountMax=3,"
    echo "               allow_other, idmap=user, follow_symlinks, compression=no"
    echo ""
    echo "Prerequisites:"
    echo "  - sshfs installed (nixpkgs.sshfs)"
    echo "  - SSH access to host 'neo' (configured in ~/.ssh/config)"
    echo "  - /etc/fuse.conf has 'user_allow_other' or run with sudo"
end

function cmd_mount_neo_blockade
    if not type -q sshfs
        log_error "sshfs not found. Add it to your NixOS configuration:"
        log_error "  environment.systemPackages = [ pkgs.sshfs ];"
        exit 1
    end

    if mountpoint -q $LOCAL_MOUNT 2>/dev/null
        log_warn "$LOCAL_MOUNT is already mounted."
        mount | grep $LOCAL_MOUNT
        exit 0
    end

    if not test -d $LOCAL_MOUNT
        log_step "Creating local mountpoint $LOCAL_MOUNT ..."
        if test (id -u) -ne 0
            log_warn "Need sudo to create $LOCAL_MOUNT"
            sudo mkdir -p $LOCAL_MOUNT
        else
            mkdir -p $LOCAL_MOUNT
        end
    end

    log_step "Mounting $REMOTE_HOST:$REMOTE_PATH -> $LOCAL_MOUNT ..."

    sshfs \
        $REMOTE_HOST:$REMOTE_PATH \
        $LOCAL_MOUNT \
        -o reconnect \
        -o ServerAliveInterval=15 \
        -o ServerAliveCountMax=3 \
        -o allow_other \
        -o idmap=user \
        -o follow_symlinks \
        -o compression=no

    log_info "Mounted successfully."
    log_info "  Remote : $REMOTE_HOST:$REMOTE_PATH"
    log_info "  Local  : $LOCAL_MOUNT"
    log_info ""
    log_info "To unmount: mount umount neo-blockade"
end

function cmd_umount_neo_blockade
    if not mountpoint -q $LOCAL_MOUNT 2>/dev/null
        log_warn "$LOCAL_MOUNT is not currently mounted. Nothing to do."
        exit 0
    end

    log_info "Unmounting $LOCAL_MOUNT ..."

    # Try fusermount first (no root needed), fall back to umount
    if type -q fusermount3
        fusermount3 -u $LOCAL_MOUNT
    else if type -q fusermount
        fusermount -u $LOCAL_MOUNT
    else
        umount $LOCAL_MOUNT
    end

    log_info "Unmounted $LOCAL_MOUNT."
end

function cmd_status
    echo "SSHFS mounts:"
    mount | grep fuse.sshfs
    or echo "(none)"
end

# Argument dispatch
set subcommand $argv[1]
set subarg $argv[2]

switch $subcommand
    case --help -h
        show_help
    case neo-blockade
        cmd_mount_neo_blockade
    case umount
        switch $subarg
            case neo-blockade
                cmd_umount_neo_blockade
            case ''
                echo "mount umount: missing target" >&2
                echo "Run 'mount --help' for usage." >&2
                exit 1
            case '*'
                echo "mount umount: unknown target '$subarg'" >&2
                echo "Run 'mount --help' for usage." >&2
                exit 1
        end
    case status
        cmd_status
    case ''
        show_help
        exit 1
    case '*'
        echo "mount: unknown subcommand '$subcommand'" >&2
        echo "Run 'mount --help' for usage." >&2
        exit 1
end
