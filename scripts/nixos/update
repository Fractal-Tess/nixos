#!/usr/bin/env bun

import { Effect, pipe } from "effect";
import { existsSync } from "fs";
import { run } from "../lib/shell";
import { log } from "../lib/log";
import { GitError, NixosBuildError } from "./errors";
import { showBanner } from "./banner";
import { checkGitConflicts, stageLocalChanges, commitChangesWithMessage, pushChanges } from "./git";
import { rebuildNixos } from "./nixos";
import { showSummary } from "./summary";
import { generateCommitMessage } from "./ai";

const NIXOS_DIR = "/home/fractal-tess/nixos";
const SKIP_GIT = process.env.NIXOS_UPDATE_NO_GIT === "1";

const program = Effect.gen(function* () {
  if (!existsSync(NIXOS_DIR)) {
    log.error(`NixOS configuration directory not found: ${NIXOS_DIR}`);
    process.exit(1);
  }

  process.chdir(NIXOS_DIR);

  if (!run(["git", "rev-parse", "--git-dir"]).ok) {
    log.error(`Not a git repository: ${NIXOS_DIR}`);
    process.exit(1);
  }

  yield* showBanner;

  if (!SKIP_GIT) {
    yield* checkGitConflicts;
    yield* stageLocalChanges;
  } else {
    log.info("Skipping git fetch/stage/commit because NIXOS_UPDATE_NO_GIT=1");
  }

  // Check if there are local changes - this determines if we commit/push later
  const hasLocalChanges = !SKIP_GIT && run(["git", "diff", "--cached", "--name-only"]).out.length > 0;

  // Start generating commit message in the background if there are changes
  let commitMessagePromise: Promise<string> | null = null;
  if (hasLocalChanges) {
    log.info("Starting AI commit message generation in background...");
    commitMessagePromise = Effect.runPromise(generateCommitMessage);
  }

  // Always run rebuild (even if no changes - for idempotency)
  yield* rebuildNixos;

  // Only commit/push if there were local changes
  if (hasLocalChanges && commitMessagePromise) {
    log.step("Finalizing commit...");
    const commitMessage = yield* Effect.promise(() => commitMessagePromise);

    const committed = yield* commitChangesWithMessage(commitMessage);
    const pushed = committed
      ? yield* pipe(pushChanges, Effect.map(() => true), Effect.catchAll(() => Effect.succeed(false)))
      : false;

    yield* showSummary(true, pushed);
  } else {
    log.step("No local changes to commit");
    log.info("Configuration rebuilt successfully, no new commits needed");
    yield* showSummary(false, false);
  }
});

const handleError = (error: GitError | NixosBuildError) => Effect.sync(() => {
  switch (error._tag) {
    case "GitError":
      log.error(`Git operation failed: ${error.operation}`);
      if (error.detail) log.dim(`  ${error.detail}`);
      break;
    case "NixosBuildError":
      log.error("NixOS rebuild failed! Check the output above and fix the issues.");
      break;
  }
  process.exit(1);
});

Effect.runPromise(
  pipe(program, Effect.catchAll(handleError))
);
