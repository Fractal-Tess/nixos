#!/usr/bin/env bash

set -euo pipefail

readonly repo_dir="${REPO_DIR:-${HOME}/nixos}"
readonly stow_dir="${repo_dir}/dotfiles"
readonly target_home="${HOME}"
readonly host_name="${HOSTNAME_VALUE:-$(hostname)}"

mkdir -p \
  "${target_home}/.config/hypr/conf.d" \
  "${target_home}/.config/waybar" \
  "${target_home}/.local/share/wallpapers/library" \
  "${target_home}/.config/colors" \
  "${target_home}/.config/RofiScripts/WallpaperChanger" \
  "${target_home}/.config/hypr/hyprconfigs" \
  "${target_home}/.config/cava/themes" \
  "${target_home}/.config/btop/themes" \
  "${target_home}/.config/qt5ct/colors" \
  "${target_home}/.config/qt6ct/colors" \
  "${target_home}/.config/gtk-3.0" \
  "${target_home}/.config/gtk-4.0"

case "${host_name}" in
  kiwi)
    waybar_config="config-kiwi.jsonc"
    monitor_config="monitors-kiwi.conf"
    ;;
  neo)
    waybar_config="config-neo.jsonc"
    monitor_config="monitors-neo.conf"
    ;;
  *)
    waybar_config="config-vd.jsonc"
    monitor_config="monitors-vd.conf"
    ;;
esac

# Remove stale files/symlinks that can make stow fail on host-specific monitor config.
rm -f "${target_home}/.config/hypr/conf.d/monitors.conf"
for f in monitors-kiwi.conf monitors-neo.conf monitors-vd.conf; do
  p="${target_home}/.config/hypr/conf.d/${f}"
  if [ -e "${p}" ] && [ ! -L "${p}" ]; then
    rm -f "${p}"
  fi
done

stow --dir "${stow_dir}" --target "${target_home}" --restow desktop

# Keep these links relative so stow can manage the directory cleanly.
ln -sfn "${waybar_config}" "${target_home}/.config/waybar/config.jsonc"
ln -sfn "${monitor_config}" "${target_home}/.config/hypr/conf.d/monitors.conf"

"${repo_dir}/scripts/wallpaper/sync-library.sh"
