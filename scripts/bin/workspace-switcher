#!/usr/bin/env fish
# Dynamic workspace switcher — swaps workspaces between active monitors

function get_active_monitors
    hyprctl monitors -j | jq -r '.[] | select(.disabled == false) | .name'
end

function swap_workspaces
    set -l monitors (get_active_monitors)
    set -l count (count $monitors)

    if test $count -ge 2
        echo "Swapping workspaces between $monitors[1] and $monitors[2]"
        hyprctl dispatch swapactiveworkspaces $monitors[1] $monitors[2]
    else if test $count -eq 1
        echo "Only one active monitor ($monitors[1]). Cannot swap."
    else
        echo "No active monitors found."
    end
end

function show_status
    echo "=== Active Monitor Configuration ==="
    set -l monitors_json (hyprctl monitors -j)
    
    echo $monitors_json | jq -r '.[] | "\(.id): \(.name) (\(.width)x\(.height)) - Disabled: \(.disabled)"'
    
    set -l active (echo $monitors_json | jq -r '[.[] | select(.disabled == false) | .name] | join(", ")')
    set -l active_count (echo $monitors_json | jq '[.[] | select(.disabled == false)] | length')
    echo ""
    echo "Active: $active ($active_count total)"
end

function show_help
    echo "Dynamic Workspace Switcher"
    echo ""
    echo "Usage: workspace-switcher [COMMAND]"
    echo ""
    echo "Commands:"
    echo "  swap    Swap workspaces between main active monitors (default)"
    echo "  status  Show current monitor configuration"
    echo "  help    Show this help message"
end

# Main
set -l cmd $argv[1]
set -q cmd[1]; or set cmd "swap"

switch $cmd
    case swap
        swap_workspaces
    case status
        show_status
    case help --help -h
        show_help
    case '*'
        echo "Unknown command: $cmd" >&2
        show_help
        exit 1
end
