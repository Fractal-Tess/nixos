#!/usr/bin/env bash
# Waybar custom module: toggle CPU boost
# Usage:
#   boost-toggle        → output JSON status for waybar
#   boost-toggle toggle → toggle CPU boost on/off

BOOST_PATH="/sys/devices/system/cpu/cpufreq/boost"

is_enabled() {
  [[ "$(cat "$BOOST_PATH" 2>/dev/null)" == "1" ]]
}

print_status() {
  if is_enabled; then
    echo '{"text": "󰓅", "tooltip": "CPU boost: enabled", "class": "active", "alt": "active"}'
  else
    echo '{"text": "󰾅", "tooltip": "CPU boost: disabled", "class": "inactive", "alt": "inactive"}'
  fi
}

case "${1:-}" in
  toggle)
    if is_enabled; then
      echo 0 | sudo tee "$BOOST_PATH" > /dev/null
      notify-send -t 2000 "CPU Boost" "Boost disabled"
    else
      echo 1 | sudo tee "$BOOST_PATH" > /dev/null
      notify-send -t 2000 "CPU Boost" "Boost enabled"
    fi
    ;;
  *)
    print_status
    ;;
esac
