#!/usr/bin/env bash

set -euo pipefail

BATTERY=/sys/class/power_supply/BAT0

capacity=$(cat "$BATTERY/capacity")
status=$(cat "$BATTERY/status")

# Only act when on battery
[[ "$status" == "Charging" || "$status" == "Full" ]] && exit 0

if (( capacity < 10 )); then
  notify-send -u critical -i battery-caution "Battery Critical" \
    "Battery at ${capacity}%. Shutting down now." \
    -h string:x-canonical-private-synchronous:battery-alert
  sleep 5
  systemctl poweroff
elif (( capacity < 20 )); then
  notify-send -u critical -i battery-low "Battery Low" \
    "Battery at ${capacity}%. Please plug in." \
    -h string:x-canonical-private-synchronous:battery-alert
fi
