#!/usr/bin/env bun
// Audio sink selector - interactive wofi menu for choosing output device
// Usage: audio-sink-selector

import { run } from "../lib/shell";

interface Sink {
  id: number;
  description: string;
  isDefault: boolean;
}

const getSinks = (): Sink[] => {
  const result = run(["wpctl", "status"]).out;
  const lines = result.split("\n");
  
  // Find the first Sinks section (audio devices)
  const sinksStart = lines.findIndex(l => l.includes("Sinks:"));
  const sourcesStart = lines.findIndex((l, i) => i > sinksStart && l.includes("Sources:"));
  
  if (sinksStart === -1) return [];
  
  const sinkLines = lines.slice(sinksStart + 1, sourcesStart > 0 ? sourcesStart : undefined);
  const sinks: Sink[] = [];
  
  for (const line of sinkLines) {
    const match = line.match(/^\s*[│├└─]*\s*(\*)?\s*(\d+)\.\s+(.+?)\s*(?:\[vol:.*\])?$/);
    if (match) {
      const isDefault = match[1] === "*";
      const id = parseInt(match[2], 10);
      const description = match[3].trim();
      sinks.push({ id, description, isDefault });
    }
  }
  
  return sinks;
};

const formatSinkEntry = (s: Sink): string => {
  const indicator = s.isDefault ? "🔊" : "  ";
  return `${indicator} ${s.description}`;
};

const comparableLabel = (entry: string): string =>
  entry.replace(/^\s*🔊\s*/u, "").trim();

const selectSink = (sinks: Sink[]): number | null => {
  const entries = sinks.map(formatSinkEntry).join("\n");
  
  run(["pkill", "wofi"]);
  
  const selection = Bun.spawnSync(
    ["wofi", "-dmenu", "-p", "Select audio output:", "--cache-file", "/dev/null"],
    { stdin: new TextEncoder().encode(entries), stdout: "pipe" }
  );
  
  if (!selection.stdout?.byteLength || selection.exitCode !== 0) return null;
  
  const selected = new TextDecoder().decode(selection.stdout).trim();
  const selectedLabel = comparableLabel(selected);
  
  // Debug: log what was selected
  console.error(`Selected: ${JSON.stringify(selected)}`);
  
  // Match the selected line back to a sink
  // The selection will be like "🔊 Description" or "  Description"
  for (const sink of sinks) {
    const entryLabel = comparableLabel(formatSinkEntry(sink));
    if (selectedLabel === entryLabel) {
      console.error(`Matched sink ${sink.id}: ${sink.description}`);
      return sink.id;
    }
  }

  const sink = sinks.find(s => s.description === selectedLabel);
  if (sink) {
    console.error(`Fallback matched sink ${sink.id}`);
    return sink.id;
  }
  
  console.error("No match found for selection");
  return null;
};

const notify = (title: string, msg: string) => {
  try {
    run(["notify-send", title, msg, "-h", "string:x-canonical-private-synchronous:audio-sink"]);
  } catch {
    // Silent fail
  }
};

// Main
const sinks = getSinks();

if (sinks.length === 0) {
  notify("Audio Error", "No audio sinks found");
  process.exit(1);
}

if (sinks.length === 1) {
  notify("Audio", `Only one sink: ${sinks[0].description}`);
  process.exit(0);
}

const sinkId = selectSink(sinks);

if (sinkId === null) {
  console.error("No sink selected");
  process.exit(0);
}

console.error(`Switching to sink ${sinkId}...`);

const result = run(["wpctl", "set-default", sinkId.toString()]);
console.error(`wpctl result: ok=${result.ok}, out=${result.out}`);

if (!result.ok) {
  notify("Audio Error", `Failed to switch: ${result.out}`);
  process.exit(1);
}

const sink = sinks.find(s => s.id === sinkId);
notify("Audio Output", `🔊 ${sink?.description ?? "Unknown"}`);
