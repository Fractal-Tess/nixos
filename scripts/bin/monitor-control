#!/usr/bin/env bun
// Individual monitor control - turn on/off specific monitors
// Usage: monitor-control [off|on|toggle|status]

import { Effect } from "effect";
import { run } from "../lib/shell";

interface Monitor {
  id: number;
  name: string;
  description: string;
  width: number;
  height: number;
  refreshRate: number;
  x: number;
  y: number;
  activeWorkspace: { id: number; name: string };
  reserved: number[];
  scale: number;
  transform: number;
  focused: boolean;
  dpmsStatus: boolean;
  vrr: boolean;
  solitary: string;
  mirror: string;
  mirrorOf: string;
  disabled: boolean;
}

const getMonitors = (): Monitor[] => {
  try {
    return JSON.parse(run(["hyprctl", "monitors", "-j"]).out);
  } catch {
    return [];
  }
};

const getEnabledMonitors = (): Monitor[] => getMonitors().filter(m => !m.disabled);

const formatMonitorEntry = (m: Monitor): string => {
  const status = m.dpmsStatus ? "🟢" : "🔴";
  const focused = m.focused ? " [focused]" : "";
  return `${status} ${m.name}: ${m.description} (${m.width}x${m.height})${focused}`;
};

const selectMonitor = (monitors: Monitor[], prompt: string): string | null => {
  const entries = monitors.map(formatMonitorEntry).join("\n");
  
  run(["pkill", "rofi"]);
  
  const selection = Bun.spawnSync(
    [
      "/run/current-system/sw/bin/rofi",
      "-plugin-path", "/run/current-system/sw/lib/rofi",
      "-dmenu",
      "-i",
      "-p", prompt,
      "-theme-str", `window { width: 28em; } inputbar { enabled: false; } mainbox { children: [ listview ]; } listview { lines: ${monitors.length}; columns: 1; spacing: 14px; } element { orientation: horizontal; spacing: 18px; padding: 22px 24px; children: [ element-text ]; } element-text { horizontal-align: 0.0; vertical-align: 0.5; font: "Adwaita Sans 18"; }`,
    ],
    { stdin: new TextEncoder().encode(entries), stdout: "pipe", stderr: "pipe" }
  );
  
  if (!selection.stdout?.byteLength || selection.exitCode !== 0) return null;
  
  const selected = new TextDecoder().decode(selection.stdout).trim();
  // Extract monitor name from selection (before the colon)
  const match = selected.match(/^\S+\s+([^:]+):/);
  return match ? match[1] : null;
};

const notify = (title: string, msg: string) =>
  run(["notify-send", title, msg, "-h", "string:x-canonical-private-synchronous:monitor-status"]);

const turnOff = Effect.sync(() => {
  const monitors = getEnabledMonitors();
  if (monitors.length === 0) {
    console.log("No enabled monitors found");
    return;
  }
  
  const name = selectMonitor(monitors, "Turn off monitor:");
  if (!name) return;
  
  run(["hyprctl", "dispatch", "dpms", "off", name]);
  notify("Monitor Off", `🔴 ${name} turned off`);
});

const turnOn = Effect.sync(() => {
  const monitors = getMonitors().filter(m => !m.dpmsStatus && !m.disabled);
  if (monitors.length === 0) {
    // If all monitors are already on, show all enabled ones
    const allEnabled = getEnabledMonitors();
    if (allEnabled.length === 0) {
      console.log("No monitors available");
      return;
    }
    
    const name = selectMonitor(allEnabled, "Turn on monitor:");
    if (!name) return;
    
    // Monitor is already on, just notify
    if (allEnabled.find(m => m.name === name)?.dpmsStatus) {
      notify("Monitor On", `🟢 ${name} is already on`);
      return;
    }
    
    run(["hyprctl", "dispatch", "dpms", "on", name]);
    notify("Monitor On", `🟢 ${name} turned on`);
    return;
  }
  
  const name = selectMonitor(monitors, "Turn on monitor:");
  if (!name) return;
  
  run(["hyprctl", "dispatch", "dpms", "on", name]);
  notify("Monitor On", `🟢 ${name} turned on`);
});

const toggle = Effect.sync(() => {
  const monitors = getEnabledMonitors();
  if (monitors.length === 0) {
    console.log("No enabled monitors found");
    return;
  }
  
  const name = selectMonitor(monitors, "Toggle monitor:");
  if (!name) return;
  
  const monitor = monitors.find(m => m.name === name);
  if (!monitor) return;
  
  const newState = monitor.dpmsStatus ? "off" : "on";
  const emoji = monitor.dpmsStatus ? "🔴" : "🟢";
  const statusText = monitor.dpmsStatus ? "off" : "on";
  
  run(["hyprctl", "dispatch", "dpms", newState, name]);
  notify(`Monitor ${statusText.toUpperCase()}`, `${emoji} ${name} turned ${statusText}`);
});

const showStatus = Effect.sync(() => {
  const monitors = getMonitors();
  
  console.log("=== Monitor Status ===\n");
  
  for (const m of monitors) {
    const power = m.dpmsStatus ? "🟢 ON" : "🔴 OFF";
    const disabled = m.disabled ? " [DISABLED]" : "";
    const focused = m.focused ? " [FOCUSED]" : "";
    
    console.log(`${m.name}: ${power}${disabled}${focused}`);
    console.log(`  Description: ${m.description}`);
    console.log(`  Resolution: ${m.width}x${m.height}@${m.refreshRate.toFixed(2)}Hz`);
    console.log(`  Position: ${m.x},${m.y}`);
    console.log(`  Scale: ${m.scale}x`);
    console.log(`  Workspace: ${m.activeWorkspace.name}`);
    console.log();
  }
});

const showHelp = Effect.sync(() => {
  console.log(`Individual Monitor Control

Usage: monitor-control [COMMAND]

Commands:
  off      Select a monitor to turn off
  on       Select a monitor to turn on
  toggle   Toggle power state of selected monitor
  status   Show status of all monitors
  help     Show this help message

Examples:
  monitor-control off     # Interactive selection to turn off
  monitor-control on      # Interactive selection to turn on
  monitor-control toggle  # Toggle selected monitor
  monitor-control status  # List all monitors`);
});

const program = Effect.gen(function* () {
  const command = process.argv[2] ?? "toggle";
  
  switch (command) {
    case "off":    yield* turnOff;    break;
    case "on":     yield* turnOn;     break;
    case "toggle": yield* toggle;     break;
    case "status": yield* showStatus; break;
    case "help": case "--help": case "-h":
      yield* showHelp;
      break;
    default:
      console.error(`Unknown command: ${command}`);
      yield* showHelp;
      process.exit(1);
  }
});

Effect.runSync(program);
