#!/usr/bin/env bash

set -euo pipefail

readonly entries=$'󰌾  Lock\n󰜉  Reboot\n  Shutdown'
readonly rofi_bin="/run/current-system/sw/bin/rofi"
readonly plugin_dir="/run/current-system/sw/lib/rofi"

choose_action() {
  if [[ -n "${POWERMENU_CHOICE:-}" ]]; then
    printf '%s\n' "${POWERMENU_CHOICE}"
    return 0
  fi

  printf '%s\n' "${entries}" | "${rofi_bin}" \
    -plugin-path "${plugin_dir}" \
    -modes "drun,run,window,calc" \
    -dmenu \
    -i \
    -p "Power" \
    -theme-str 'window { width: 22em; } inputbar { enabled: false; } mainbox { children: [ listview ]; } listview { lines: 3; columns: 1; spacing: 14px; } element { orientation: horizontal; spacing: 18px; padding: 22px 24px; children: [ element-text ]; } element-text { horizontal-align: 0.0; vertical-align: 0.5; font: "Adwaita Sans 18"; }'
}

run_action() {
  local chosen="$1"

  case "${chosen}" in
    Lock)
      if [[ -n "${POWERMENU_DRY_RUN:-}" ]]; then
        printf 'lock\n'
      else
        hyprlock
      fi
      ;;
    Reboot)
      if [[ -n "${POWERMENU_DRY_RUN:-}" ]]; then
        printf 'reboot\n'
      else
        systemctl reboot
      fi
      ;;
    Shutdown)
      if [[ -n "${POWERMENU_DRY_RUN:-}" ]]; then
        printf 'shutdown\n'
      else
        systemctl poweroff
      fi
      ;;
    *)
      exit 0
      ;;
  esac
}

selection="$(choose_action || true)"
selection="$(printf '%s' "${selection}" | tr -d '\r' | sed '/^$/d' | head -n 1)"
selection="$(printf '%s' "${selection}" | sed 's/^[^[:alpha:]]*//')"

if [[ -z "${selection}" ]]; then
  exit 0
fi

run_action "${selection}"
