#!/usr/bin/env fish
# ai — Unified AI provider launcher for Claude Code
#
# Launches Claude Code (or Auto-Claude AppImage) with a chosen AI provider's
# API endpoint and credentials pre-configured via environment variables.
# Secrets are read from ~/.config/secrets/ at runtime.
#
# Dependencies: claude, appimage-run
# Usage: ai <provider> [--auto-claude] [claude-args...]
#
# Providers:
#   kimi        Kimi K2 via moonshot.ai Anthropic-compatible endpoint
#   minimax     MiniMax M2.1 via minimax.io Anthropic-compatible endpoint
#   z-ai        Z.AI GLM-4.7/4.5 via z.ai Anthropic-compatible endpoint
#   codex       GPT 5.6 Sol via CLIProxyAPI (requires codex OAuth login)
#
# Flags (provider-level, before extra args):
#   --auto-claude   Launch Auto-Claude AppImage instead of claude CLI
#                   (only supported for z-ai and minimax)
#   --help, -h      Show this help message

set -l APPIMAGE "$HOME/.local/bin/Auto-Claude-2.7.1-linux-x86_64.AppImage"

function _ai_help
    echo "Usage: ai <provider> [--auto-claude] [claude-args...]"
    echo ""
    echo "Providers:"
    echo "  kimi        Kimi K2 via moonshot.ai (kimi-k2-thinking-turbo)"
    echo "  minimax     MiniMax M2.1 via minimax.io"
    echo "  z-ai        Z.AI GLM-4.7/4.5 models"
    echo "  codex       GPT 5.6 Sol via CLIProxyAPI (requires: cliproxyapi -codex-login)"
    echo ""
    echo "Flags (placed after provider):"
    echo "  --auto-claude   Launch Auto-Claude AppImage instead of claude CLI"
    echo "                  (supported for: z-ai, minimax)"
    echo "  --help, -h      Show this help message"
    echo ""
    echo "All remaining arguments are forwarded to the underlying command."
    echo ""
    echo "Examples:"
    echo "  ai kimi"
    echo "  ai kimi --dangerously-skip-permissions"
    echo "  ai minimax --auto-claude"
    echo "  ai z-ai --auto-claude"
    echo "  ai z-ai -p 'Hello'"
    echo "  ai codex"
end

# No arguments — show help
if test (count $argv) -eq 0
    _ai_help
    exit 0
end

# Top-level --help / -h
if contains -- --help $argv; or contains -- -h $argv
    _ai_help
    exit 0
end

set -l provider $argv[1]
set -l rest_args $argv[2..]

# Check for --auto-claude in remaining args
set -l use_appimage false
set -l forward_args

for arg in $rest_args
    if test "$arg" = "--auto-claude"
        set use_appimage true
    else
        set forward_args $forward_args $arg
    end
end

# ── Helper: read secret file ─────────────────────────────────────────────────
function _read_secret
    set -l path $argv[1]
    if not test -f "$path"
        echo "Error: secret file not found: $path" >&2
        exit 1
    end
    cat "$path"
end

# ── Provider dispatch ────────────────────────────────────────────────────────
switch $provider

    case kimi
        set -l apikey (_read_secret "$HOME/.config/secrets/moonshot_ai")

        # Clear conflicting vars
        set -e ANTHROPIC_AUTH_TOKEN
        set -e ANTHROPIC_BASE_URL

        set -x ANTHROPIC_BASE_URL "https://api.moonshot.ai/anthropic"
        set -x ANTHROPIC_AUTH_TOKEN (string trim $apikey)
        set -x ANTHROPIC_MODEL "kimi-k2-thinking-turbo"
        set -x ANTHROPIC_DEFAULT_OPUS_MODEL "kimi-k2-thinking-turbo"
        set -x ANTHROPIC_DEFAULT_SONNET_MODEL "kimi-k2-thinking-turbo"
        set -x ANTHROPIC_DEFAULT_HAIKU_MODEL "kimi-k2-thinking-turbo"
        set -x CLAUDE_CODE_SUBAGENT_MODEL "kimi-k2-thinking-turbo"

        echo "Configured Claude Code to use Kimi K2 Thinking Turbo via Anthropic-compatible API."

        if test "$use_appimage" = true
            echo "Warning: --auto-claude is not supported for kimi; launching claude CLI instead." >&2
        end

        if not type -q claude
            echo "Error: claude not found in PATH" >&2
            exit 1
        end
        exec claude --dangerously-skip-permissions $forward_args

    case minimax
        set -l apikey (_read_secret "$HOME/.config/secrets/minimax/apikey")

        # Clear conflicting vars (per MiniMax docs)
        set -e ANTHROPIC_AUTH_TOKEN
        set -e ANTHROPIC_BASE_URL

        set -x ANTHROPIC_BASE_URL "https://api.minimax.io/anthropic"
        set -x ANTHROPIC_AUTH_TOKEN (string trim $apikey)
        set -x ANTHROPIC_MODEL "MiniMax-M2.1"
        set -x ANTHROPIC_SMALL_FAST_MODEL "MiniMax-M2.1"
        set -x ANTHROPIC_DEFAULT_SONNET_MODEL "MiniMax-M2.1"
        set -x ANTHROPIC_DEFAULT_OPUS_MODEL "MiniMax-M2.1"
        set -x ANTHROPIC_DEFAULT_HAIKU_MODEL "MiniMax-M2.1"

        echo "Configured Claude Code to use MiniMax-M2.1 via Anthropic-compatible API."

        if test "$use_appimage" = true
            set -x GRAPHITI_ENABLED true
            if not type -q appimage-run
                echo "Error: appimage-run not found in PATH" >&2
                exit 1
            end
            if not test -f "$APPIMAGE"
                echo "Error: Auto-Claude AppImage not found: $APPIMAGE" >&2
                exit 1
            end
            exec appimage-run $APPIMAGE $forward_args
        else
            if not type -q claude
                echo "Error: claude not found in PATH" >&2
                exit 1
            end
            exec claude --dangerously-skip-permissions $forward_args
        end

    case z-ai
        set -l apikey (_read_secret "$HOME/.config/secrets/z-ai/apikey")

        set -x ANTHROPIC_BASE_URL "https://api.z.ai/api/anthropic"
        set -x ANTHROPIC_AUTH_TOKEN (string trim $apikey)
        set -x ANTHROPIC_DEFAULT_HAIKU_MODEL "glm-4.5-air"
        set -x ANTHROPIC_DEFAULT_SONNET_MODEL "glm-4.7"
        set -x ANTHROPIC_DEFAULT_OPUS_MODEL "glm-4.7"

        echo "Configured Claude Code to use Z.AI GLM-4.7/4.5 models via Anthropic-compatible API."

        if test "$use_appimage" = true
            set -x GRAPHITI_ENABLED true
            if not type -q appimage-run
                echo "Error: appimage-run not found in PATH" >&2
                exit 1
            end
            if not test -f "$APPIMAGE"
                echo "Error: Auto-Claude AppImage not found: $APPIMAGE" >&2
                exit 1
            end
            exec appimage-run $APPIMAGE $forward_args
        else
            if not type -q claude
                echo "Error: claude not found in PATH" >&2
                exit 1
            end
            exec claude --dangerously-skip-permissions $forward_args
        end

    case codex
        # GPT 5.6 Sol via CLIProxyAPI (Codex OAuth subscription)
        if not type -q cliproxyapi
            echo "Error: cliproxyapi not found in PATH (install via nixos-rebuild)" >&2
            exit 1
        end

        set -l config_dir "$HOME/.config/cliproxyapi"
        set -l config_file "$config_dir/config.yaml"
        set -l auth_dir "$HOME/.cli-proxy-api"
        set -l state_dir "$HOME/.local/state/cliproxyapi"
        set -l log_file "$state_dir/cliproxyapi.log"
        set -l proxy_url "http://127.0.0.1:8317"
        set -l proxy_key "local-claude-codex-9f4c2a7e6b1d"

        mkdir -p "$config_dir" "$auth_dir" "$state_dir"; or begin
            echo "Error: could not create CLIProxyAPI directories" >&2
            exit 1
        end
        chmod 700 "$config_dir" "$auth_dir" "$state_dir"; or begin
            echo "Error: could not secure CLIProxyAPI directories" >&2
            exit 1
        end
        printf '%s\n' \
            'host: 127.0.0.1' \
            'port: 8317' \
            'auth-dir: "~/.cli-proxy-api"' \
            'api-keys:' \
            "  - $proxy_key" \
            >"$config_file"; or begin
            echo "Error: could not write CLIProxyAPI config: $config_file" >&2
            exit 1
        end
        chmod 600 "$config_file"; or begin
            echo "Error: could not secure CLIProxyAPI config: $config_file" >&2
            exit 1
        end

        function _cliproxy_models --no-scope-shadowing
            curl --fail --silent --show-error \
                -H "Authorization: Bearer $proxy_key" \
                "$proxy_url/v1/models"
        end

        set -l models (_cliproxy_models)
        if test $status -ne 0
            echo "Starting CLIProxyAPI proxy..."
            nohup cliproxyapi -config "$config_file" </dev/null >>"$log_file" 2>&1 &
            disown

            set -l proxy_ready false
            for attempt in (seq 1 20)
                set models (_cliproxy_models)
                if test $status -eq 0
                    set proxy_ready true
                    break
                end
                sleep 0.25
            end

            if test "$proxy_ready" != true
                echo "Error: CLIProxyAPI did not become healthy after 20 attempts." >&2
                echo "See daemon log: $log_file" >&2
                exit 1
            end
        end

        set -x ANTHROPIC_BASE_URL "$proxy_url"
        set -x ANTHROPIC_AUTH_TOKEN "$proxy_key"
        set -x CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY 1
        set -x CLAUDE_CODE_SUBAGENT_MODEL gpt-5.6-sol
        set -x CLAUDE_CODE_ALWAYS_ENABLE_EFFORT 1
        set -x CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY 3
        set -x ENABLE_TOOL_SEARCH false

        if not string match -q -r '"id"[[:space:]]*:[[:space:]]*"gpt-5\.6-sol"' -- (string join \n -- $models)
            echo "Error: CLIProxyAPI does not expose gpt-5.6-sol; Codex OAuth credentials may be unavailable." >&2
            echo "Run this one-time login command:" >&2
            echo "cliproxyapi -config $config_file -codex-login" >&2
            exit 1
        end

        echo "Configured Claude Code to use GPT 5.6 Sol via CLIProxyAPI (Codex subscription)."

        if test "$use_appimage" = true
            echo "Warning: --auto-claude is not supported for codex; launching claude CLI instead." >&2
        end

        if not type -q claude
            echo "Error: claude not found in PATH" >&2
            exit 1
        end
        exec claude --model gpt-5.6-sol --dangerously-skip-permissions $forward_args

    case '*'
        echo "Error: unknown provider '$provider'" >&2
        echo "" >&2
        _ai_help >&2
        exit 1
end
