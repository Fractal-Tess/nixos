#!/usr/bin/env fish

set -g SCRIPT_NAME (path basename (status filename))
set -g DEFAULT_MODEL_DIR /mnt/vault/ai/models/llms
set -g DEFAULT_CTX 65536
set -g DEFAULT_DEVICES CUDA0,CUDA1
set -g DEFAULT_HOST 0.0.0.0
set -g DEFAULT_PORT 8080
set -g DEFAULT_SPLIT_MODE layer
set -g DEFAULT_TENSOR_SPLIT 1,1
set -g DEFAULT_GPU_LAYERS 999

function show_help
    echo "Usage: $SCRIPT_NAME [options] [-- extra llama-server args]"
    echo
    echo "Start llama.cpp's HTTP server with a selected GGUF model."
    echo
    echo "Options:"
    echo "  --model PATH|NAME       Model path or basename fragment"
    echo "  --model-dir PATH        Model search directory (default: $DEFAULT_MODEL_DIR)"
    echo "  --ctx N                 Context size (default: $DEFAULT_CTX)"
    echo "  --device LIST           Devices, e.g. CUDA0 or CUDA0,CUDA1"
    echo "  --host ADDR             Bind host (default: $DEFAULT_HOST)"
    echo "  --port N                Port (default: $DEFAULT_PORT)"
    echo "  --split-mode MODE       none|layer|row|tensor (default: $DEFAULT_SPLIT_MODE)"
    echo "  --tensor-split A,B      Tensor split across GPUs (default: $DEFAULT_TENSOR_SPLIT)"
    echo "  --gpu-layers N          GPU layers to offload (default: $DEFAULT_GPU_LAYERS)"
    echo "  --flash-attn on|off     Flash attention (default: on)"
    echo "  --warmup on|off         Warmup pass (default: off)"
    echo "  --list                  List available GGUF models and exit"
    echo "  --dry-run               Print command without starting the server"
    echo "  --help                  Show this help"
    echo
    echo "Examples:"
    echo "  $SCRIPT_NAME --model qwen3.6-27b-opusdistil --ctx 65536"
    echo "  $SCRIPT_NAME --model /mnt/vault/ai/models/llms/phi-4-Q6_K.gguf --device CUDA1"
    echo "  $SCRIPT_NAME --model gemma --port 8081 -- --jinja"
end

function die -a message
    echo "$SCRIPT_NAME: $message" >&2
    exit 1
end

function resolve_model -a selector model_dir
    if test -n "$selector"
        if test -f "$selector"
            realpath "$selector"
            return 0
        end

        set -l matches (find "$model_dir" -maxdepth 3 -type f -name "*.gguf" | sort | rg -i --fixed-strings "$selector")
        set -l count (count $matches)

        if test $count -eq 1
            echo $matches[1]
            return 0
        else if test $count -gt 1
            printf '%s\n' $matches | fzf --prompt="Select model > " --height=40% --reverse
            return $status
        end

        return 1
    end

    find "$model_dir" -maxdepth 3 -type f -name "*.gguf" | sort | fzf --prompt="Select model > " --height=40% --reverse
end

set -l model_dir $DEFAULT_MODEL_DIR
set -l model_selector
set -l ctx $DEFAULT_CTX
set -l device $DEFAULT_DEVICES
set -l host $DEFAULT_HOST
set -l port $DEFAULT_PORT
set -l split_mode $DEFAULT_SPLIT_MODE
set -l tensor_split $DEFAULT_TENSOR_SPLIT
set -l gpu_layers $DEFAULT_GPU_LAYERS
set -l flash_attn on
set -l warmup off
set -l dry_run 0
set -l list_only 0
set -l passthrough

while test (count $argv) -gt 0
    switch $argv[1]
        case --help -h
            show_help
            exit 0
        case --model
            test (count $argv) -ge 2; or die "missing value for --model"
            set model_selector $argv[2]
            set -e argv[1..2]
        case --model-dir
            test (count $argv) -ge 2; or die "missing value for --model-dir"
            set model_dir $argv[2]
            set -e argv[1..2]
        case --ctx
            test (count $argv) -ge 2; or die "missing value for --ctx"
            set ctx $argv[2]
            set -e argv[1..2]
        case --device
            test (count $argv) -ge 2; or die "missing value for --device"
            set device $argv[2]
            set -e argv[1..2]
        case --host
            test (count $argv) -ge 2; or die "missing value for --host"
            set host $argv[2]
            set -e argv[1..2]
        case --port
            test (count $argv) -ge 2; or die "missing value for --port"
            set port $argv[2]
            set -e argv[1..2]
        case --split-mode
            test (count $argv) -ge 2; or die "missing value for --split-mode"
            set split_mode $argv[2]
            set -e argv[1..2]
        case --tensor-split
            test (count $argv) -ge 2; or die "missing value for --tensor-split"
            set tensor_split $argv[2]
            set -e argv[1..2]
        case --gpu-layers
            test (count $argv) -ge 2; or die "missing value for --gpu-layers"
            set gpu_layers $argv[2]
            set -e argv[1..2]
        case --flash-attn
            test (count $argv) -ge 2; or die "missing value for --flash-attn"
            set flash_attn $argv[2]
            set -e argv[1..2]
        case --warmup
            test (count $argv) -ge 2; or die "missing value for --warmup"
            set warmup $argv[2]
            set -e argv[1..2]
        case --list
            set list_only 1
            set -e argv[1]
        case --dry-run
            set dry_run 1
            set -e argv[1]
        case --
            set passthrough $argv[2..-1]
            break
        case '*'
            die "unknown option: $argv[1]"
    end
end

test -d "$model_dir"; or die "model directory not found: $model_dir"
command -sq llama-server; or die "llama-server not found in PATH"

if test $list_only -eq 1
    find "$model_dir" -maxdepth 3 -type f -name "*.gguf" | sort
    exit 0
end

set -l model_path (resolve_model "$model_selector" "$model_dir")
test -n "$model_path"; or die "could not resolve model selection"
test -f "$model_path"; or die "model not found: $model_path"

set -l flash_flag --flash-attn
if test "$flash_attn" = off
    set flash_flag --flash-attn off
end

set -l warmup_flag --no-warmup
if test "$warmup" = on
    set warmup_flag --warmup
end

set -l cmd \
    llama-server \
    -m "$model_path" \
    --host "$host" \
    --port "$port" \
    --ctx-size "$ctx" \
    --device "$device" \
    --split-mode "$split_mode" \
    --tensor-split "$tensor_split" \
    --gpu-layers "$gpu_layers" \
    $flash_flag \
    $warmup_flag \
    $passthrough

echo "Model: $model_path"
echo "Host:  $host:$port"
echo "CTX:   $ctx"
echo "GPU:   $device"

if test $dry_run -eq 1
    printf '%q ' $cmd
    echo
    exit 0
end

exec $cmd
