{
///////////////////////////
 "layer": "top",
 "output": "DP-4",
 "position": "top",
 "height": 40,
 "spacing": 0,
 "margin-top": 10,
 "margin-left": 10,
 "margin-right": 10,
 "margin-bottom": 0,
  "reload_style_on-change": true,
///////////////////////////
 "modules-left": [
 "custom/System",
 "hyprland/workspaces",
],
 "modules-center": [
  "hyprland/window",
],
 "modules-right": [
  "disk#root",
  "disk#vault",
  "disk#backup",
   "group/idlevol",
   "group/sysmon",
   "group/netblue",
   "group/datetime",
   "custom/notifications",
  "group/traywermen",
 ],
///////////////////////////
 "include": [
  "/home/fractal-tess/.config/waybar/modules.jsonc",
 ],
 "group/sysmon": {
  "orientation": "horizontal",
  "modules": [
    "cpu",
    "custom/gpu#nvidia",
    "custom/gpu-mem#nvidia",
    "memory",
    "custom/swap"
  ]
 },
 }
