{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "cssPriority": "user",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "control-center-width": 420,
  "control-center-margin-top": 18,
  "control-center-margin-bottom": 18,
  "control-center-margin-right": 18,
  "notification-window-width": 380,
  "notification-2fa-action": true,
  "notification-grouping": true,
  "timeout": 8,
  "timeout-low": 4,
  "timeout-critical": 0,
  "image-visibility": "when-available",
  "widgets": ["title", "dnd", "mpris", "volume", "notifications"],
  "widget-config": {
    "title": { "text": "Control Center", "clear-all-button": true, "button-text": "Clear" },
    "dnd": { "text": "Focus mode" },
    "notifications": { "vexpand": true },
    "mpris": { "image-size": 84, "image-radius": 12 },
    "volume": { "label": "Vol", "show-per-app": false, "show-per-app-icon": true }
  }
}
